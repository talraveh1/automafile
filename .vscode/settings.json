{
    "explorer.fileNesting.patterns": {
        "README.md": "*.md",
        "config.jsonc": "*.json, *.jsonc, *.toml, *.yml, CMake*.example, .gitignore, .gitattributes, .dockerignore, Dockerfile, .clangd, .clang-format, CMakeLists.txt, .env"
    },
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv",
    "terminal.integrated.environmentChangesRelaunch": false,
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true
    },
    "explorerExclude.backup": {}
}
