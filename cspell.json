{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "language": "en",
  "ignorePaths": [
    ".git/**",
    ".venv/**",
    "**/__pycache__/**",
    "**/*.pyc",
    "*.egg-info/**",
    ".pytest_cache/**",
    "data/**",
    "memory/**",
    "build/**",
    "cspell.json",
    "uv.lock",
    "poetry.lock"
  ],
  "ignoreRegExpList": [
    "W5M0MpCehiHzreSzNTczkc9d"
  ],
  "words": [
    "dragndoc",
    "Gotenberg",
    "NSSM",
    "NTFS",
    "Ollama",
    "Tesseract",
    "Tika",
    "Typer",
    "beautifulsoup",
    "ebooklib",
    "exiftool",
    "frontmatter",
    "gershayim",
    "libmagic",
    "ollama",
    "openpyxl",
    "piexif",
    "pikepdf",
    "poppler",
    "pydantic",
    "pypdf",
    "pytesseract",
    "pytest",
    "setuptools",
    "tessdata",
    "traineddata",
    "winget",
    "addopts",
    "apos",
    "autouse",
    "dataclass",
    "docinfo",
    "dotenv",
    "exif",
    "getexif",
    "itxt",
    "noscript",
    "officedocument",
    "openxmlformats",
    "pagesizes",
    "pathlib",
    "pdfgen",
    "pdfinfo",
    "pnginfo",
    "presentationml",
    "pycache",
    "pyproject",
    "rels",
    "spreadsheetml",
    "stdlib",
    "testpaths",
    "timespec",
    "tobytes",
    "wordprocessingml",
    "xmpmeta",
    "xpacket",
    "behaviour",
    "crdownload",
    "idempotently",
    "relinks",
    "renameable",
    "rescan",
    "spath",
    "trax",
    "unmetadataed",
    "utime",
    "venv",
    "weirdext",
    "worklist",
    "worklists",
    "treewalk",
    "olefile",
    "pystray",
    "distutils",
    "Sandboxed"
  ],
  "languageSettings": [
    {
      "languageId": "markdown",
      "ignoreRegExpList": [
        "/^```[\\s\\S]*?^```/gm",
        "/`[^`]+`/g"
      ]
    }
  ],
  "overrides": [
    {
      "filename": "dragndoc/metadata/native.py",
      "words": ["Cehi", "Hzre", "Tczkc"]
    },
    {
      "filename": "tests/**/*.py",
      "words": ["amet", "הודעה", "עולם", "שלום"]
    }
  ]
}
