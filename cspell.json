    "addopts",
    "apos",
    "attribs",
    "autouse",
    "caplog",
    "colname",
    "creationflags",
    "dataclass",
    "docinfo",
    "dotenv",
    "endlocal",
    "errorlevel",
    "executescript",
    "exif",
