    "pydantic",
    "pypdf",
    "pytesseract",
    "pytest",
    "pythonw",
    "schtasks",
    "setuptools",
    "shcore",
    "shutil",
    "tessdata",
    "traineddata",
    "tzdata",
    "winget",
    "AUTOINCREMENT",
