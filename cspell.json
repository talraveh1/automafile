    "weirdext",
    "worklist",
    "worklists",
    "treewalk",
    "olefile",
    "pystray",
    "distutils",
    "Sandboxed"
  ],
  "languageSettings": [
    {
      "languageId": "markdown",
      "ignoreRegExpList": [
        "/^```[\\s\\S]*?^```/gm",
        "/`[^`]+`/g"
      ]
    }
  ],
  "overrides": [
    {
      "filename": "dragndoc/metadata/native.py",
      "words": ["Cehi", "Hzre", "Tczkc"]
    },
    {
      "filename": "tests/**/*.py",
      "words": ["amet", "הודעה", "עולם", "שלום"]
    },
    {
      "filename": "tests/test_caps.py",
      "words": ["ghijk", "ghijkl"]
    },
    {
      "filename": "tests/test_events_toaster.py",
      "words": ["cpath"]
    },
    {
      "filename": "tests/test_llm_parse.py",
      "words": ["Nuri", "Sommerville"]
    }
  ]
}
