// Drag'n'Doc runtime configuration.
//
// Copy this file to config.jsonc and adjust to your environment.
//
// Environment variables override these values. Top-level keys map to their
// uppercase form (e.g. DOCS, INBOX); nested keys concatenate the group
// name and the leaf key, joined by `_` and uppercased — e.g. watch.settle is
// overridden by WATCH_SETTLE, logs.level by LOGS_LEVEL, ocr.min_text_chars
// by OCR_MIN_TEXT_CHARS.

{
  // Root of the user's documents tree. The pipeline only reads/writes within
  // this directory; nothing else.
  "docs": "C:\\Users\\<you>\\OneDrive\\Documents",

  // Drop-zone subfolder under docs. Filed documents end up at
  // docs/<Category>[/<SubCategory>]/<smart-name>.<ext>.
  "inbox": "Inbox",

  // Logging level: DEBUG | INFO | WARNING | ERROR.
  "logs": {
    "level": "INFO",
    // Roll the active log file once it reaches this many lines.
    "max_lines": 10000,
    // Keep at most this many log files (current + rotated backups).
    "max_files": 5
  },

  // Watcher behaviour.
  "watch": {
    // Seconds to wait after a file appears before processing it (lets large
    // files finish copying / writing).
    "settle": 2,
    // Polling interval used by the inbox watcher, in seconds.
    "polling": 5
  },

  // OCR thresholds and caps.
  "ocr": {
    // Hard cap on extracted text per document, in characters.
    "max_total_chars": 6000,
    // PDFs with fewer text-layer characters than this are OCR'd in full.
    "min_text_chars": 100,
    // A page with fewer characters than this is considered sparse.
    "min_page_chars": 50,
    // Fraction of pages allowed to be sparse before falling back to full OCR.
    "sparse_page_ratio": 0.3
  },

  // Local LLM server reachable over HTTP.
  "ollama": {
    // Base URL of the Ollama server.
    "url": "http://localhost:11434",
    // Model name as registered in Ollama (e.g. `ollama pull aya-expanse:8b`).
    "model": "aya-expanse:8b"
  },

  // Tesseract OCR engine.
  "tesseract": {
    // `+`-separated list of language packs (must be installed locally).
    "langs": "heb+eng",
    // Empty = autodetect on PATH. Otherwise an absolute path to tesseract.exe.
    "bin": "",
    // Empty = use the tesseract installation default. Otherwise the directory
    // containing the *.traineddata files.
    "prefix": ""
  }
}
